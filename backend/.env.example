# Copy to .env and adjust. Every value has a safe default; the app runs with an empty file.

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./learning.db
# Postgres (hosts like Render/Neon give a postgres:// URL; the app auto-converts it for asyncpg):
# DATABASE_URL=postgresql+asyncpg://learn:learn@localhost:5432/learning
# PG_SSL=true            # for hosted Postgres requiring SSL (e.g. Neon); auto-on if URL has sslmode=require

# --- Auth ---
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# Leave blank/default and the app generates a random per-process secret at startup
# (tokens reset on restart and will not work across instances — set this in production).
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days
ALLOW_REGISTRATION=true             # set false to lock a public instance to existing accounts
AI_RATE_PER_MIN=30                  # per-user cap on tutor calls per minute (<=0 disables)

# --- AI tutor: pick ONE provider (or leave blank; the app still runs, tutor degrades) ---
LLM_PROVIDER=auto        # auto | anthropic | groq | none  (auto picks Groq if its key is set, else Claude)

# Option A — Groq: FREE tier, no credit card. Key: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_JUDGE_MODEL=llama-3.1-8b-instant
OPENAI_BASE_URL=https://api.groq.com/openai/v1   # works for any OpenAI-compatible host (OpenAI, Together, OpenRouter, Ollama)

# Option B — Anthropic (Claude). Key: https://console.anthropic.com
ANTHROPIC_API_KEY=
TUTOR_MODEL=claude-opus-4-8
JUDGE_MODEL=claude-haiku-4-5

# --- Optional infra ---
REDIS_URL=               # e.g. redis://localhost:6379/0 ; blank = disabled

# --- Content (blank = use bundled content/; set a path to override) ---
CONTENT_DIR=

# --- Dev seed account (local SQLite only) ---
# Auto-created only on local SQLite. On a Postgres database the seed is skipped while
# the password is the public default below (so a hosted deploy has no known account) —
# register in the UI, or set a non-default SEED_PASSWORD to seed on Postgres too.
SEED_EMAIL=visakh@local
SEED_PASSWORD=learn

# --- Cache / memory / tracing (safe defaults; work without any of these set) ---
CACHE_ENABLED=true                 # cache grades (Redis if REDIS_URL set, else in-process)
CACHE_TTL_SECONDS=86400
TUTOR_HISTORY_MESSAGES=12          # LangChain-trimmed tutor history window
TRACE_ENABLED=true                 # record tokens / est. cost / latency per LLM call

# --- Embeddings for semantic search / RAG (optional) ---
EMBEDDINGS_PROVIDER=auto           # auto | local | openai | hash | none
# best quality (local, free):  pip install sentence-transformers
# or a hosted API:
# EMBEDDINGS_PROVIDER=openai
# EMBEDDINGS_API_KEY=
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1
# EMBEDDINGS_API_MODEL=text-embedding-3-small
